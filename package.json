{
  "name": "kurogi-motion",
  "version": "0.2.0",
  "description": "Local-first motion design editor with autonomous MCP video workflows.",
  "author": "Kurogi Motion",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "typecheck": "tsc --noEmit",
    "audit:templates": "node scripts/audit-templates.mjs",
    "audit:effects": "node scripts/audit-effects.mjs",
    "audit:loops": "node scripts/audit-loops.mjs",
    "audit:text-canvas": "node scripts/audit-text-canvas.mjs",
    "audit:shapes": "node scripts/audit-shapes.mjs",
    "audit:export": "node scripts/audit-export.mjs",
    "audit:foundation-v2": "node scripts/audit-foundation-v2.mjs",
    "audit:recovery": "node scripts/audit-recovery.mjs",
    "audit:multiscene": "node scripts/audit-multiscene.mjs",
    "audit:design-tools": "node scripts/audit-design-tools.mjs",
    "audit:clipping-mask": "node scripts/audit-clipping-mask.mjs",
    "audit:animation-workflow": "node scripts/audit-animation-workflow.mjs",
    "audit:preview-recovery": "node scripts/audit-preview-recovery.mjs",
    "audit:editor-command-ui": "node scripts/audit-editor-command-ui.mjs",
    "audit:ui-cleanup": "node scripts/audit-ui-cleanup.mjs",
    "audit": "npm run audit:templates && npm run audit:effects && npm run audit:loops && npm run audit:text-canvas && npm run audit:shapes && npm run audit:export && npm run audit:foundation-v2 && npm run audit:recovery && npm run audit:multiscene && npm run audit:design-tools && npm run audit:clipping-mask && npm run audit:animation-workflow && npm run audit:preview-recovery && npm run audit:editor-command-ui && npm run audit:ui-cleanup && npm run audit:mcp && npm run audit:mcp-protocol && npm run audit:audio-mcp",
    "build": "npm run typecheck && vite build",
    "desktop": "npm run build && electron .",
    "package": "npm run build && electron-builder --win --x64",
    "mcp": "electron . --mcp",
    "audit:mcp": "node scripts/audit-mcp.mjs",
    "audit:mcp-protocol": "node scripts/audit-mcp-protocol.mjs",
    "audit:audio-mcp": "node scripts/audit-audio-mcp.mjs",
    "audit:render-smoke": "node scripts/audit-render-smoke.mjs",
    "audit:mcp-live": "node scripts/audit-installed-mcp-live.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@remotion/bundler": "^4.0.365",
    "@remotion/player": "^4.0.365",
    "@remotion/renderer": "^4.0.365",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.365",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kurogi.motion",
    "productName": "Kurogi Motion",
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/**/*",
      "package.json",
      "tsconfig.json",
      "mcp/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    }
  }
}
